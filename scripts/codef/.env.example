# CODEF API credentials — codef.io 가입 후 마이페이지에서 발급
# DEMO 환경부터 시작 권장 (무료, 실데이터 가능). 안정화되면 PRODUCTION으로 전환.

CODEF_DEMO_CLIENT_ID=
CODEF_DEMO_CLIENT_SECRET=
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=

# CODEF 공개키 — codef.io 마이페이지 > 인증정보 > 공개키
# 한 줄 base64 문자열
CODEF_PUBLIC_KEY=

# 어느 환경으로 호출할지: DEMO | SANDBOX | PRODUCT
CODEF_SERVICE_TYPE=DEMO

# 신한은행 organization 코드 (developer.codef.io > 은행 코드표 확인)
# 신한은행은 보통 0088
SHINHAN_ORG_CODE=0088

# 신한은행 인터넷뱅킹 ID/PW (스크립트 실행 시에만 메모리에 로드, 평문 저장 금지)
# .env에 적기 싫으면 register_account.py 실행 시 prompt로 받게 비워둬도 됨
SHINHAN_LOGIN_ID=
SHINHAN_LOGIN_PW=

# register_account.py가 발급해 출력하는 connectedId (수동으로 여기에 붙여넣기)
SHINHAN_CONNECTED_ID=

# 가져올 계좌번호들 (콤마 구분, 하이픈 제거)
SHINHAN_ACCOUNTS=110618270351,110618091082
